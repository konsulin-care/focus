{
  "name": "focus",
  "version": "0.0.0-dev",
  "main": "dist/main/main.js",
  "dependencies": {
    "@fontsource/plus-jakarta-sans": "^5.2.8",
    "axios": "^1.6.0",
    "better-sqlite3": "^12.6.2",
    "i18next": "^26.0.3",
    "i18next-browser-languagedetector": "^8.2.0",
    "keytar": "^7.9.0",
    "lucide-react": "^1.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^17.0.2",
    "typescript": "^5.3.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@tailwindcss/vite": "^4.1.18",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.2.0",
    "@types/react": "^19.2.11",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.1.0",
    "electron-builder": "^26.7.0",
    "eslint": "^10.0.2",
    "globals": "^17.5.0",
    "prettier": "^3.1.0",
    "tailwindcss": "^4.1.18",
    "ts-node": "^10.9.2",
    "vite": "^8.0.4",
    "vitest": "^4.0.18"
  },
  "scripts": {
    "dev": "electron .",
    "build": "tsc && vite build",
    "build:main": "tsc",
    "build:renderer": "vite build",
    "electron-rebuild": "electron-rebuild",
    "package": "npm run build && electron-builder",
    "validate-timing": "ts-node src/validate-timing.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "build": {
    "appId": "com.konsulin.focus",
    "productName": "F.O.C.U.S. Assessment",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "portable"
      ],
      "artifactName": "focus-${version}.exe"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.medical",
      "artifactName": "focus-${version}.dmg"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "artifactName": "focus-${version}.AppImage"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/konsulin-care/focus.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/konsulin-care/focus/issues"
  },
  "homepage": "https://github.com/konsulin-care/focus#readme",
  "description": ""
}
